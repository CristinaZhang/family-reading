.btn {
  width: 100%;
  padding: 20rpx;
  border: none;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

.btn.primary {
  background: #1989fa;
  color: #ffffff;
}

.btn.secondary {
  background: #f0f0f0;
  color: #333333;
  margin-top: 15rpx;
}

input {
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  padding: 10px;
  background: #fff;
}