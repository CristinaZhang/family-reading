.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #f6f7fb;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  width: 80%;
  max-width: 500rpx;
}

.scan-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.hint {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 32rpx;
}

.isbn-display {
  width: 100%;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  margin-bottom: 32rpx;
}

.label {
  font-size: 24rpx;
  color: #666666;
  margin-right: 12rpx;
}

.isbn {
  font-size: 24rpx;
  color: #333333;
  word-break: break-all;
}

.rescan-btn {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  background-color: #1989fa;
  color: #ffffff;
  border-radius: 8rpx;
  margin-top: 20rpx;
}