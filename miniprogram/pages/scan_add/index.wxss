.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 20rpx;
  background: #f5f5f5;
}

.content {
  width: 100%;
  max-width: 500rpx;
  padding: 40rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.scan-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  border-radius: 60rpx;
}

.scan-icon .icon {
  font-size: 60rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

/* 模式选择标签 */
.mode-tabs {
  display: flex;
  margin-bottom: 40rpx;
  border-bottom: 2rpx solid #e5e5e5;
}

.mode-tab {
  flex: 1;
  padding: 20rpx;
  font-size: 24rpx;
  color: #666;
  border-bottom: 3rpx solid transparent;
}

.mode-tab.active {
  color: #1989fa;
  border-bottom-color: #1989fa;
  font-weight: bold;
}

/* 单本添加模式 */
.form-input {
  margin-bottom: 40rpx;
}

.submit-btn {
  width: 100%;
  padding: 20rpx;
  background: #1989fa;
  color: #ffffff;
  border: none;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-top: 30rpx;
}

.input-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 15rpx;
  text-align: left;
}

.input-label .required {
  color: #ff4d4f;
}

.input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 10rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

/* 批量输入模式 */
.batch-input {
  margin-bottom: 40rpx;
}

.hint {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-bottom: 15rpx;
  text-align: left;
}

.textarea {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 10rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
  resize: none;
}

.batch-btn {
  width: 100%;
  padding: 20rpx;
  background: #1989fa;
  color: #ffffff;
  border: none;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 返回按钮 */
.back-btn {
  margin-top: 40rpx;
  padding: 20rpx;
  background: #f0f0f0;
  color: #333;
  border: none;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
}