.container {
  min-height: 100vh;
  background-color: #f6f7fb;
}

.loading, .error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 40rpx;
}

.error button {
  margin-top: 20rpx;
  width: 200rpx;
}

.content {
  padding: 20rpx;
}

.section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.add-btn {
  font-size: 24rpx;
  color: #1989fa;
}

.family-name-row {
  padding: 16rpx 0;
}

.family-name {
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
}

.member-list {
  margin-top: 8rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #e6f7ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: #1890ff;
}

.member-name {
  font-size: 26rpx;
  color: #333333;
}

.empty-hint {
  padding: 30rpx 0;
  text-align: center;
}

.empty-hint text {
  font-size: 24rpx;
  color: #999999;
}

.add-member-input {
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.input {
  width: 100%;
  padding: 12rpx 16rpx;
  background-color: #ffffff;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.input-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.btn-confirm {
  background-color: #1989fa;
  color: #ffffff;
}

.btn-cancel {
  background-color: #f0f0f0;
  color: #666666;
}

.back-btn {
  margin-top: 20rpx;
  background-color: #f0f0f0;
  color: #333333;
  border-radius: 8rpx;
  font-size: 28rpx;
}
