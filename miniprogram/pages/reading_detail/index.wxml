<view class="container">
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{error}}" class="error">
    <text>加载失败，请重试</text>
    <button bindtap="refresh">重新加载</button>
  </view>

  <view wx:else class="content">
    <view class="book-info">
      <image class="cover" src="{{reading.book.cover}}" mode="aspectFit" wx:if="{{reading.book.cover}}" />
      <view class="cover-placeholder" wx:else>
        <text class="cover-icon">📚</text>
      </view>
      <view class="info">
        <text class="title">{{reading.book.title}}</text>
        <text class="author">{{reading.book.author}}</text>
        <text class="isbn" wx:if="{{reading.book.isbn}}">ISBN: {{reading.book.isbn}}</text>
      </view>
    </view>

    <view class="status-section">
      <text class="section-title">阅读状态</text>
      <view class="status-buttons">
        <view
          wx:for="{{['wishlist', 'reading', 'rereading', 'finished', 'paused']}}"
          wx:key="*this"
          class="status-btn {{item}}"
          bindtap="changeStatus"
          data-status="{{item}}"
        >
          {{statusLabels[item]}}
        </view>
      </view>
      <view class="current-status">
        <text>当前状态：</text>
        <text class="status-badge {{reading.status}}">{{statusLabels[reading.status] || reading.status}}</text>
      </view>
      <view class="date-info">
        <text class="date">开始日期: {{reading.startDate}}</text>
        <text class="date">更新日期: {{reading.updatedAt}}</text>
      </view>
    </view>

    <view class="progress-section">
      <text class="section-title">阅读进度</text>
      <view class="progress-container">
        <text class="progress-text">{{progress}}%</text>
        <slider
          value="{{progress}}"
          min="0"
          max="100"
          bindchange="updateProgress"
          activeColor="#1989fa"
          backgroundColor="#e5e5e5"
        />
      </view>
      <button class="save-btn" bindtap="saveProgress">保存进度</button>
    </view>

    <view class="note-section">
      <text class="section-title">阅读笔记</text>
      <view class="note">
        <text>{{reading.note || '暂无笔记'}}</text>
      </view>
    </view>
  </view>
</view>
