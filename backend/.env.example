APP_ENV=dev
APP_DEBUG=1

# SQLite by default. Example Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/family_reading
DATABASE_URL=sqlite:///./data/app.db

# Dev login
ENABLE_DEV_LOGIN=1

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# WeChat Mini Program
# 本地开发请将微信密钥放在 local.env 中（不会被提交）
# WECHAT_APP_ID=wx...
# WECHAT_APP_SECRET=...